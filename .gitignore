# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!windows-portable-pack/.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# legacy scripts & debug artifacts
/scripts/_legacy/
lint_report.txt

# Google Credentials
google_credentials.json
google_client_secret.json
windows-portable-pack/exocad-config.json

# Visual brainstorming companion
.superpowers/

# Local scratch & temporary files
/scratch/
/horarios/

# Patient data backups & PII exports (NEVER commit — Ley 25.326)
/data/backups/
/outputs/*.json
*backup_pacientes*
backup-pacientes*
*.bak
